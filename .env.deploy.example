# ── Static assets (JS + CSS) ──────────────────────────────────────────────────
#
# Path where built main.js / main.css should be copied.
#
# For a local venv-based test project, run this with the venv active:
#   python -c "import schematic, os; print(os.path.join(os.path.dirname(schematic.__file__), 'static', 'schematic'))"
#
# For a Docker-based test project using local.yml, set this to the
# schematic_src/ directory in the testbed (volume-mounted to the static dir):
#   DEPLOY_TARGET=/path/to/testbed/schematic_src
#
DEPLOY_TARGET=/path/to/.venv/lib/python3.x/site-packages/schematic/static/schematic

# ── Python source files ───────────────────────────────────────────────────────
#
# Path where schematic/*.py should be copied.
#
# For a local venv-based test project, go two levels up from DEPLOY_TARGET:
#   PYTHON_DEPLOY_TARGET=/path/to/.venv/lib/python3.x/site-packages/schematic
#
# For a Docker-based test project using local.yml, set this to the
# schematic_py_src/ directory in the testbed (volume-mounted to the package dir):
#   PYTHON_DEPLOY_TARGET=/path/to/testbed/schematic_py_src
#
# Leave unset to skip Python deployment.
#PYTHON_DEPLOY_TARGET=
